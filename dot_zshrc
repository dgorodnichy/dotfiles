function tag_release() {
    local conflict_branches=()
    local branches=("develop" "stage" "stage2" "stage3")

    # Get current branch
    local current_branch
    current_branch=$(git rev-parse --abbrev-ref HEAD)
    git pull origin "$current_branch"

    # Set tag name
    local tag_name
    if [ -n "$1" ]; then
        tag_name="$1"
        echo "ℹ️  Using provided tag name: $tag_name"
    else
        tag_name="v$(date +'%Y.%m.%d')"
        echo "ℹ️  Using date-based tag name: $tag_name"
    fi

    # Check if tag already exists
    if git rev-parse "$tag_name" >/dev/null 2>&1; then
        echo "❌ Error: Tag $tag_name already exists."
        return 1
    fi

    # Create and push tag
    echo "🏷 Creating tag $tag_name on current branch ($current_branch)..."
    git tag "$tag_name"
    if [ $? -ne 0 ]; then
        echo "❌ Error: Failed to create tag."
        return 1
    fi

    echo "📤 Pushing tag $tag_name to remote..."
    git push origin "$tag_name"
    if [ $? -ne 0 ]; then
        echo "❌ Error: Failed to push tag."
        return 1
    fi

    # Merge to production first
    echo "🔄 Merging to production branch..."
    git checkout production
    if [ $? -ne 0 ]; then
        echo "❌ Error: Failed to checkout production branch."
        return 1
    fi

    git pull origin production
    if git merge --no-ff --no-edit "$current_branch"; then
        echo "✅ Successfully merged to production."
        git push origin production
    else
        echo "❌ Merge conflict detected when merging to production!"
        echo "⚠️ Please resolve the conflicts manually and then continue the process."
        git merge --abort
        return 1
    fi

    # Merge to other branches
    # TODO: fetch origin branches
    for branch in "${branches[@]}"; do
        if [[ "$branch" == "$current_branch" ]]; then
          echo "⏩ Skipping current branch ($current_branch)"
          continue  # Skip the current branch
        fi

        echo "🔄 Merging to $branch branch..."
        git checkout "$branch"
        if [ $? -ne 0 ]; then
            echo "⚠️ Warning: Failed to checkout $branch branch. Skipping..."
            conflict_branches+=("$branch")
            continue
        fi

        git pull origin "$branch"
        if git merge --no-ff --no-edit production; then
            echo "✅ Successfully merged to $branch."
            git push origin "$branch"
        else
            echo "⚠️ Merge conflict detected when merging to $branch!"
            conflict_branches+=("$branch")
            git merge --abort
            git checkout - # Return to previous branch
        fi
    done

    # Return to original branch
    git checkout "$current_branch"
    echo "🔙 Returned to original branch: $current_branch"

    # Summary
    echo -e "\n📊 Release Summary:"
    echo "✅ Created and pushed tag: $tag_name"
    echo "✅ Merged to production branch"

    if [ ${#conflict_branches[@]} -eq 0 ]; then
        echo "✅ Successfully merged to all target branches"
    else
        echo "⚠️  Merge conflicts occurred in the following branches:"
        for branch in "${conflict_branches[@]}"; do
            echo "   - $branch"
        done
        echo "ℹ️  You'll need to resolve these conflicts manually."
    fi
}

function community_retag() {
    if [ $# -ne 2 ]; then
        echo "Usage: community_retag <source_image:tag> <target_image:tag>"
        echo "Example: community_retag sso-backend-stage:df928770 sso-backend:df928770"
        return 1
    fi

    local source_image="$1"
    local target_image="$2"
    local registry="cr.yandex/crp707ie48p49ctj5fel"

    local full_source="${registry}/${source_image}"
    local full_target="${registry}/${target_image}"

    docker login --username iam --password $(yc iam create-token) cr.yandex

    echo "🚀 Starting image retagging operation"
    echo "   Source: $full_source"
    echo "   Target: $full_target"
    echo "----------------------------------------"

    # Step 1: Pull the source image
    echo "📥 Pulling source image..."
    if docker pull "$full_source"; then
        echo "✅ Successfully pulled $full_source"
    else
        echo "❌ Failed to pull $full_source"
        return 1
    fi

    # Step 2: Tag the image
    echo "🏷️  Tagging image..."
    if docker tag "$full_source" "$full_target"; then
        echo "✅ Successfully tagged $full_source -> $full_target"
    else
        echo "❌ Failed to tag image"
        return 1
    fi

    # Step 3: Push the target image
    echo "📤 Pushing target image..."
    if docker push "$full_target"; then
        echo "✅ Successfully pushed $full_target"
    else
        echo "❌ Failed to push $full_target"
        return 1
    fi

    # Step 4: Remove source image
    echo "🧹 Cleaning up source image..."
    if docker rmi "$full_source"; then
        echo "✅ Successfully removed $full_source"
    else
        echo "⚠️  Warning: Could not remove $full_source (may be in use)"
    fi

    # Step 5: Remove target image
    echo "🧹 Cleaning up target image..."
    if docker rmi "$full_target"; then
        echo "✅ Successfully removed $full_target"
    else
        echo "⚠️  Warning: Could not remove $full_target (may be in use)"
    fi

    echo "----------------------------------------"
    echo "🎉 Retagging operation completed successfully!"
    echo "   Image $target_image is now available in the registry"
}

